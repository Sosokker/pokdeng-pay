{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pokdeng-promptpay",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "pokdeng.sirin.dev",
      "custom_domain": true
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  }
}
